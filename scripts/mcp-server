#!/bin/bash
# ArtCRM Supervisor MCP Server Launcher
# Starts the MCP server via stdio transport for Claude Code / Claude Desktop.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_ROOT"

exec "$HOME/.local/bin/uv" run python -c "
import sys
from pathlib import Path
sys.path.insert(0, str(Path.cwd()))
from src.mcp.server import server
server.run()
" "$@"
