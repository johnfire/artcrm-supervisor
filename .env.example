# Shared PostgreSQL database (same instance as theo-hits-the-road)
DATABASE_URL=postgresql://user:password@localhost/artcrm

# AI backends
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=

# Proton Bridge (IMAP + SMTP — must be running locally)
PROTON_IMAP_HOST=127.0.0.1
PROTON_IMAP_PORT=1143
PROTON_SMTP_HOST=127.0.0.1
PROTON_SMTP_PORT=1025
PROTON_EMAIL=your@proton.me
PROTON_PASSWORD=bridge_app_password

# Server
HOST=127.0.0.1
PORT=8000
